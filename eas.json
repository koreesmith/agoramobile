{
  "cli": {
    "version": ">= 8.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "image": "macos-sequoia-15.5-xcode-26.0" }
    },
    "ios-simulator": {
      "extends": "development",
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "image": "macos-sequoia-15.5-xcode-26.0", "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "autoIncrement": true,
      "ios": { "image": "macos-sequoia-15.5-xcode-26.0" }
    }
  },
  "submit": {
    "production": {}
  }
}
